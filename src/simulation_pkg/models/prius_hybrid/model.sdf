        <xyz>0 -8.4e-05 0.999999</xyz>
        <limit>
          <lower>-7.85</lower>
          <upper>7.85</upper>
          <effort>1000000</effort>
          <velocity>-1</velocity>
        </limit>
        <dynamics>
          <spring_reference>0</spring_reference>
          <spring_stiffness>0</spring_stiffness>
          <damping>1</damping>
          <friction>0</friction>
        </dynamics>
      </axis>
      <physics>
        <ode>
          <limit>
            <cfm>0</cfm>
            <erp>0.2</erp>
          </limit>
          <suspension>
            <cfm>0</cfm>
            <erp>0.2</erp>
          </suspension>
        </ode>
      </physics>
    </joint>
    <static>0</static>
    <allow_auto_disable>1</allow_auto_disable>

    <!-- fl_axle -->
    <!-- fr_axle -->

    <!-- front_left_wheel_joint -->
    <joint name='front_left_combined_joint' type='universal'>
      <parent>chassis</parent>
      <child>front_left_wheel</child>  <!-- fl_axle -->
      <pose>0 0 0 -0.087266 0 0</pose>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <!-- +- 50 degrees -->
          <lower>-0.8727</lower> <!-- -0.5 후진 시 바퀴 회전 제한 -->
          <upper>0.8727</upper>
          <effort>1000000</effort> <!-- 100 회전 힘 제한 -->
          <velocity>-1</velocity> <!-- 1 회전 속도 제한 -->
        </limit>
        <dynamics>
          <spring_reference>0</spring_reference>
          <spring_stiffness>0</spring_stiffness>
          <damping>0</damping> <!-- 0.7 후진 시 더 높은 댐핑 -->
          <friction>0</friction> <!-- 15.0 후진 시 더 높은 마찰 -->
        </dynamics>
      </axis>
      <axis2>
        <xyz>1 0 0</xyz>
        <limit>
          <lower>-1e+16</lower>
          <upper>1e+16</upper>
          <effort>1000000</effort> <!-- 100 회전 힘 제한 -->
          <velocity>-1</velocity> <!-- 1 회전 속도 제한 -->
        </limit>
        <dynamics>
          <spring_reference>0</spring_reference>
          <spring_stiffness>0</spring_stiffness>
          <damping>0</damping> <!-- 0.7 후진 시 더 높은 댐핑 -->
          <friction>18.0474</friction>
        </dynamics>
      </axis2>
      <physics>
        <ode>
          <limit>
            <cfm>0</cfm>
            <erp>0.2</erp> <!-- 0.9 후진 시 반응 조정 -->
          </limit>
          <suspension>
            <cfm>0</cfm>  <!-- 0.02 서스펜션에 대한 물리적 반응 -->
            <erp>0.2</erp>  <!-- 0.9 서스펜션 반응을 후진에 맞게 조정 -->
          </suspension>
        </ode>
      </physics>
    </joint>

